# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/notesapp"

# NextAuth
NEXTAUTH_SECRET="change-me-in-production-use-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# MinIO / S3
STORAGE_ENDPOINT="localhost"
STORAGE_PORT="9000"
STORAGE_ACCESS_KEY="minioadmin"
STORAGE_SECRET_KEY="minioadmin"
STORAGE_BUCKET="notes-files"
STORAGE_USE_SSL="false"
# For Railway S3 production, set these instead:
# AWS_S3_BUCKET=
# AWS_S3_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Groq AI
GROQ_API_KEY="gsk_..."

# App
NODE_ENV="development"
